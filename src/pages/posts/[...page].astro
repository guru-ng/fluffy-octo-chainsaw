---
import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import PageLayout from "@/layouts/Base.astro";
import { getMicrocmsPosts, getMicrocmsPostsCount } from "@/data/microcms";
import type { GetStaticPaths, Page } from "astro";
import { Icon } from "astro-icon/components";

const MAX_POSTS_PER_PAGE = 10;

export const getStaticPaths = (async ({ paginate }) => {
	const totalCount = await getMicrocmsPostsCount();

	// Create an array of posts for pagination. (We keep it simple for now.)
	// If you have many posts, switch this to a real “offset/limit” pagination strategy.
	const pageSize = Math.max(MAX_POSTS_PER_PAGE, 100);
	const all: any[] = [];
	for (let offset = 0; offset < totalCount; offset += pageSize) {
		const items = await getMicrocmsPosts({ limit: pageSize, offset });
		all.push(...items);
	}

	return paginate(all, {
		pageSize: MAX_POSTS_PER_PAGE,
		props: {},
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<any>;
}

const { page } = Astro.props;

const meta = {
	description: "Read my collection of posts and the things that interest me",
	title: "Posts",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Previous Page",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Next Page →",
			url: page.url.next,
		},
	}),
};

const groupedByYear = page.data.reduce<Record<string, any[]>>((acc, p) => {
	const year = new Date(p.publishDate).getFullYear();
	(acc[year] ??= []).push(p);
	return acc;
}, {});

const descYearKeys = Object.keys(groupedByYear).sort((a, b) => +b - +a);
---

<PageLayout meta={meta}>
	<div class="mb-6 flex items-center gap-3">
		<h1 class="title">Posts</h1>
		<a class="text-accent" href="/rss.xml" target="_blank">
			<span class="sr-only">RSS feed</span>
			<Icon aria-hidden="true" class="h-6 w-6" focusable="false" name="mdi:rss" />
		</a>
	</div>

	<div class="grid sm:grid-cols-[3fr_1fr] sm:gap-x-8 sm:gap-y-16">
		<div>
			{
				descYearKeys.map((yearKey) => (
					<section aria-labelledby={`year-${yearKey}`}>
						<h2 id={`year-${yearKey}`} class="title text-lg">
							<span class="sr-only">Posts in</span>
							{yearKey}
						</h2>
						<ul class="mt-5 mb-16 space-y-4 text-start">
							{groupedByYear[yearKey]?.map((p) => (
								<li class="grid gap-2 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
									<PostPreview post={p} />
								</li>
							))}
						</ul>
					</section>
				))
			}
			<Pagination {...paginationProps} />
		</div>
	</div>
</PageLayout>
