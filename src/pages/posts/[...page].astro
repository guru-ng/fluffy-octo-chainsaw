---
import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import PageLayout from "@/layouts/Base.astro";
import { getMicrocmsPosts, getMicrocmsPostsCount } from "@/data/microcms";
import type { GetStaticPaths, Page } from "astro";
import { Icon } from "astro-icon/components";

const MAX_POSTS_PER_PAGE = 10;

export const getStaticPaths = (async ({ paginate }) => {
	const totalCount = await getMicrocmsPostsCount();

	// For now: fetch enough posts and paginate client-side at build time.
	// (Replace with true offset pagination later if needed.)
	const pageSize = Math.max(MAX_POSTS_PER_PAGE, 100);
	const all: any[] = [];
	for (let offset = 0; offset < totalCount; offset += pageSize) {
		const items = await getMicrocmsPosts({ limit: pageSize, offset });
		all.push(...items);
	}

	return paginate(all, {
		pageSize: MAX_POSTS_PER_PAGE,
		props: {},
	});
}) satisfies GetStaticPaths;

interface Props {
	page: Page<any>;
}

const { page } = Astro.props;

const meta = {
	description: "Read my collection of posts and the things that interest me",
	title: "Posts",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Previous Page",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Next Page →",
			url: page.url.next,
		},
	}),
};
---

<PageLayout meta={meta}>
	<div class="mb-6 flex items-center gap-3">
		<h1 class="title">Posts</h1>
		<a class="text-accent" href="/rss.xml" target="_blank">
			<span class="sr-only">RSS feed</span>
			<Icon aria-hidden="true" class="h-6 w-6" focusable="false" name="mdi:rss" />
		</a>
	</div>

	<ul class="space-y-4">
		{
			page.data.map((p: any) => (
				<li class="grid gap-2 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
					<PostPreview post={p} withDesc />
				</li>
			))
		}
	</ul>

	<Pagination {...paginationProps} />
</PageLayout>
