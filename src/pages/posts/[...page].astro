---
import Pagination from "@/components/Paginator.astro";
import PostPreview from "@/components/blog/PostPreview.astro";
import PageLayout from "@/layouts/Base.astro";
import { getMicrocmsPosts, getMicrocmsPostsCount } from "@/data/microcms";
import type { GetStaticPaths, Page } from "astro";
import { Icon } from "astro-icon/components";

export const getStaticPaths = (async ({ paginate }) => {
	const PAGE_SIZE = 10; // same as MAX_POSTS_PER_PAGE — redefined here so it's in scope
	try {
		const totalCount = await getMicrocmsPostsCount();

		// microCMS caps `limit` at 100 per request, so page through all posts in
		// batches of 100 and collect them, then paginate into PAGE_SIZE chunks.
		const fetchSize = 100;
		const all: any[] = [];
		for (let offset = 0; offset < totalCount; offset += fetchSize) {
			const items = await getMicrocmsPosts({ limit: fetchSize, offset });
			all.push(...items);
		}

		// Newest first so pagination order is stable as the blog grows.
		all.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());

		return paginate(all, { pageSize: PAGE_SIZE, props: {} });
	} catch (error) {
		console.warn("[posts/page] Failed to fetch from microCMS, building with empty list:", error);
		return paginate([], { pageSize: PAGE_SIZE, props: {} });
	}
}) satisfies GetStaticPaths;

interface Props {
	page: Page<any>;
}

const { page } = Astro.props;

const meta = {
	description: "Read my collection of posts and the things that interest me",
	title: "Posts",
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
			text: "← Previous Page",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
			text: "Next Page →",
			url: page.url.next,
		},
	}),
};
---

<PageLayout meta={meta}>
	<div class="mb-6 flex items-center gap-3">
		<h1 class="title">Posts</h1>
		<a class="text-accent" href={`${import.meta.env.BASE_URL}rss.xml`} target="_blank">
			<span class="sr-only">RSS feed</span>
			<Icon aria-hidden="true" class="h-6 w-6" focusable="false" name="mdi:rss" />
		</a>
	</div>

	<ul class="space-y-4">
		{
			page.data.map((p: any) => (
				<li class="grid gap-2 sm:grid-cols-[auto_1fr] sm:[&_q]:col-start-2">
					<PostPreview post={p} withDesc />
				</li>
			))
		}
	</ul>

	<Pagination {...paginationProps} />
</PageLayout>
